module split (
    input clk,
    input rst_n,
    input en,
    input [15:0] data_in,

    output reg [1:0] symbol_out,
    output reg valid_out
);

reg [15:0] data_reg;
reg [2:0] cnt;

//////////////////////////////////////////////////
// LOAD DATA
//////////////////////////////////////////////////
always @(posedge clk or negedge rst_n) begin
    if (!rst_n)
        data_reg <= 16'b0;
    else if (en)
        data_reg <= data_in;
end

//////////////////////////////////////////////////
// COUNTER
//////////////////////////////////////////////////
always @(posedge clk or negedge rst_n) begin
    if (!rst_n)
        cnt <= 3'd0;
    else if (en)
        cnt <= cnt + 1;
    else
        cnt <= 3'd0;
end

//////////////////////////////////////////////////
// OUTPUT LOGIC (MUX)
//////////////////////////////////////////////////
always @(*) begin
    symbol_out = data_reg[(cnt*2)+1 -: 2];
end

//////////////////////////////////////////////////
// VALID SIGNAL
//////////////////////////////////////////////////
always @(posedge clk or negedge rst_n) begin
    if (!rst_n)
        valid_out <= 0;
    else if (cnt == 3'd7 && en)
        valid_out <= 1;
    else
        valid_out <= 0;
end

endmodule
